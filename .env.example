# Cognitio environment configuration.
#
# Copy to `.env` and fill in real values. `cognitio_config.Settings` reads this file
# (and process environment variables, which take precedence). Comma-separated values are
# accepted for the list-typed settings (NOTION_ROOT_IDS, FALLBACK_ACL_PRINCIPALS).

# --- Database (required) -----------------------------------------------------------------
# Async SQLAlchemy / asyncpg connection URL for the persistent development database.
DATABASE_URL=postgresql+asyncpg://cognitio:cognitio@localhost:5432/cognitio
# Disposable database used by the `integration` test suite. Leave unset to skip those tests.
TEST_DATABASE_URL=postgresql+asyncpg://cognitio:cognitio@localhost:5432/cognitio_test

# --- Notion connector --------------------------------------------------------------------
# Internal integration token (secret). Required to run the Notion connector.
NOTION_TOKEN=
# Page / database IDs that bound the scanned subtree (comma-separated).
NOTION_ROOT_IDS=

# --- Anthropic / extraction --------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Embeddings --------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# Full version identifier that pins the HNSW index/query space. Bump on any model change.
EMBEDDING_MODEL_VERSION=text-embedding-3-small/1
OPENAI_API_KEY=

# --- Fallback ACL ------------------------------------------------------------------------
# Principals granted access when a source exposes no usable permission metadata
# (comma-separated). Empty means such records are visible to no one.
FALLBACK_ACL_PRINCIPALS=

# --- Worker timing -----------------------------------------------------------------------
WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_CLAIM_BATCH=10
WORKER_STALE_LOCK_SECONDS=300.0
WORKER_MAX_ATTEMPTS=5
